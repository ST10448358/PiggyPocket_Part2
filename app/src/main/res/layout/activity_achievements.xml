<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/card_bg">

    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_orange_gradient"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="52dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Achievements 🏆"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintStart_toEndOf="@+id/btnBack"
        app:layout_constraintTop_toTopOf="@+id/btnBack"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="@string/your_progress_n0_4"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivA1" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvA1Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivA1" android:layout_marginLeft="16dp" android:text="First Step 🐣" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvA1Desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvA1Title" android:layout_toRightOf="@id/ivA1" android:layout_marginLeft="16dp" android:text="Log your first expense to hatch!" android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivA2" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvA2Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivA2" android:layout_marginLeft="16dp" android:text="Savings Sprout 🌱" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvA2Desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvA2Title" android:layout_toRightOf="@id/ivA2" android:layout_marginLeft="16dp" android:text="Add 5 expenses to see it grow" android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivA3" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvA3Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivA3" android:layout_marginLeft="16dp" android:text="Budget Boss 💼" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvA3Desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvA3Title" android:layout_toRightOf="@id/ivA3" android:layout_marginLeft="16dp" android:text="Stay under budget for 3 categories" android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivA4" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvA4Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivA4" android:layout_marginLeft="16dp" android:text="Money Master 👑" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvA4Desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvA4Title" android:layout_toRightOf="@id/ivA4" android:layout_marginLeft="16dp" android:text="Total spending over R5000 logged" android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Minimum Spending Goal Achievement -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvMinGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivMinGoal" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvMinGoalTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivMinGoal" android:layout_marginLeft="16dp" android:text="Minimum Goal Achieved! 🎯" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvMinGoalDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvMinGoalTitle" android:layout_toRightOf="@id/ivMinGoal" android:layout_marginLeft="16dp" android:text="You've reached your minimum spending target." android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Maximum Spending Goal Achievement -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvMaxGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <ImageView android:id="@+id/ivMaxGoal" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_lock" android:alpha="0.5"/>
                    <TextView android:id="@+id/tvMaxGoalTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toRightOf="@id/ivMaxGoal" android:layout_marginLeft="16dp" android:text="Safe Zone Keeper 🛡️" android:textStyle="bold" android:textSize="16sp" android:textColor="#BDBDBD"/>
                    <TextView android:id="@+id/tvMaxGoalDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tvMaxGoalTitle" android:layout_toRightOf="@id/ivMaxGoal" android:layout_marginLeft="16dp" android:text="Stayed under your maximum spending goal." android:textSize="13sp" android:textColor="#BDBDBD"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
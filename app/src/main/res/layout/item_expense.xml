<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tvExpIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_edittext"
        android:backgroundTint="#F8F9FE"
        android:gravity="center"
        android:text="🛍️"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvExpName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:text="Expense Name"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/tvExpIcon"
        app:layout_constraintTop_toTopOf="@id/tvExpIcon"
        app:layout_constraintEnd_toStartOf="@+id/tvExpAmount" />

    <TextView
        android:id="@+id/tvExpCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        app:layout_constraintStart_toStartOf="@id/tvExpName"
        app:layout_constraintTop_toBottomOf="@id/tvExpName" />

    <TextView
        android:id="@+id/tvExpAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="-R0.00"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/ivChevron"
        app:layout_constraintTop_toTopOf="@id/tvExpName" />

    <TextView
        android:id="@+id/tvExpDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01/01/2023"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        app:layout_constraintEnd_toEndOf="@+id/tvExpAmount"
        app:layout_constraintTop_toBottomOf="@id/tvExpAmount" />

    <ImageView
        android:id="@+id/ivChevron"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:alpha="0.3"
        android:src="@android:drawable/ic_media_play"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>